{
  "$schema": "https://example.com/macaron.schema.json",
  "name": "macaron-pink",
  "version": "0.0.1",
  "description": "A pastel theme preview",
  "flavors": [
    {
      "name": "Rose",
      "color": "#FFB6C1",
      "sweetness": 8,
      "isLimited": true,
      "tags": ["floral", "spring"]
    },
    {
      "name": "Lavender",
      "color": "#E6E6FA",
      "sweetness": 6,
      "isLimited": false,
      "tags": ["floral", "calm"]
    }
  ],
  "settings": {
    "darkMode": false,
    "fontSize": 14,
    "fontFamily": null,
    "lineHeight": 1.625,
    "maxItems": 1000,
    "discount": -0.15,
    "precision": 1.23e-4,
    "breakpoints": [320, 768, 1024, 1440],
    "nested": {
      "flags": [true, false, null],
      "matrix": [
        [1, 2, 3],
        [4, 5, 6]
      ]
    }
  }
}
