  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#b88ca5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage.type",
        "storage.modifier",
        "keyword.other",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#d5467a"
      }
    },
    {
      "name": "Import / export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#fb6376"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#3a9b6e"
      }
    },
    {
      "name": "Template string",
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#3a9b6e"
      }
    },
    {
      "name": "Template expression",
      "scope": [
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#5d2a42"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#3a9b8e"
      }
    },
    {
      "name": "Escape char",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#9b5bd2"
      }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#9b5bd2"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#5d2a42"
      }
    },
    {
      "name": "Property / attribute",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#2d8ab5"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "parameter"
      ],
      "settings": {
        "foreground": "#d5467a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Number / Boolean / Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.other"
      ],
      "settings": {
        "foreground": "#b38b00"
      }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#c1376a"
      }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#c1376a"
      }
    },
    {
      "name": "HTML/JSX tag",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#d5467a"
      }
    },
    {
      "name": "HTML/JSX attribute",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9b5bd2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operator / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#5d2a42aa"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#fb6376"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#fff6f4",
        "background": "#c1376a"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#d5467a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#c1376a"
      }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#9b5bd2"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#2d8ab5",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#3a9b6e"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "support.type.property-name.json",
        "string.quoted.double.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#d5467a"
      }
    },
    {
      "name": "CSS property name",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#d5467a"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#3a9b6e"
      }
    },
    {
      "name": "CSS selector class",
      "scope": [
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#9b5bd2"
      }
    },
    {
      "name": "CSS selector id",
      "scope": [
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#c1376a"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "parameter": { "foreground": "#d5467a", "italic": true },
    "property": "#2d8ab5",
    "property.readonly": "#2d8ab5",
    "variable.readonly": "#b38b00",
    "variable.defaultLibrary": "#c1376a",
    "function.defaultLibrary": "#9b5bd2",
    "class": "#c1376a",
    "interface": "#c1376a",
    "type": "#c1376a",
    "enum": "#c1376a",
    "enumMember": "#b38b00",
    "namespace": "#c1376a",
    "macro": "#fb6376",
    "decorator": "#fb6376"
  }
}
